VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional fallback if you don't want Supabase for the stream yet:
VITE_LIVE_STREAM_URL=

# --- Montage worker (Vercel serverless only; never expose service role to the client) ---
# SUPABASE_URL=            # same project as VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY=
# MONTAGE_WORKER_SECRET=   # long random string; Edge Function uses the same value to call Vercel
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# MONTAGE_MAX_USERS=25     # cap premium users processed per invocation

# Supabase Edge Function `montage-cron` secrets (Dashboard → Functions → Secrets):
# CRON_SECRET=             # Bearer token for invoking the Edge Function (pg_cron / manual)
# VERCEL_MONTAGE_WORKER_URL=https://YOUR_DEPLOYMENT.vercel.app/api/montage-worker
# MONTAGE_WORKER_SECRET=   # must match Vercel MONTAGE_WORKER_SECRET
