VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional fallback if you don't want Supabase for the stream yet:
VITE_LIVE_STREAM_URL=

# --- Buyer-grade analytics / monitoring ---
# Product analytics (PostHog). Used for funnels, retention, cohorts, and lifecycle events.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Default off — set true only after verifying PostHog masking in staging.
VITE_POSTHOG_AUTOCAPTURE=false

# Growth analytics (Plausible). Used for traffic, pageviews, and selected conversion events.
VITE_PLAUSIBLE_DOMAIN=5pmsomewhere.live
# VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Reliability analytics (Sentry). Used for frontend errors, traces, and replay-on-error.
VITE_SENTRY_DSN=
VITE_APP_ENV=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
VITE_SENTRY_REPLAY_SAMPLE_RATE=0
VITE_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1

# Keep off unless you explicitly want email attached to PostHog/Sentry identities.
VITE_ANALYTICS_INCLUDE_EMAIL=false

# --- Montage worker (runs on Railway/Fly/etc. or locally; never expose service role to the client) ---
# SUPABASE_URL=            # same project as VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY=
# MONTAGE_WORKER_SECRET=   # long random string; Edge Function uses the same value to call the worker
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# MONTAGE_MAX_USERS=25     # cap premium users processed per invocation
# PORT=8787                # optional; HTTP port for npm run montage-worker

# Supabase Edge Function `montage-cron` secrets (Dashboard → Functions → Secrets):
# CRON_SECRET=             # Bearer token for invoking the Edge Function (pg_cron / manual)
# VERCEL_MONTAGE_WORKER_URL=https://YOUR-WORKER.example.com   # full URL of montage worker (POST root)
# MONTAGE_WORKER_SECRET=   # must match worker MONTAGE_WORKER_SECRET

# --- Premium subscription / Stripe (Supabase Edge Functions only — NOT in Vite) ---
# Set on the linked Supabase project:  supabase secrets set NAME=value
# Go-live runbook: docs/STRIPE_GO_LIVE.md
# STRIPE_SECRET_KEY=        # sk_test_... for dev, sk_live_... for production
# STRIPE_PRICE_ID=          # price_... from the matching Stripe mode (test vs live)
# STRIPE_WEBHOOK_SECRET=    # whsec_... from the webhook endpoint in that same mode
# SITE_URL=https://5pmsomewhere.live  # Checkout / Billing Portal return URL
