VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional fallback if you don't want Supabase for the stream yet:
VITE_LIVE_STREAM_URL=

# --- Montage worker (runs on Railway/Fly/etc. or locally; never expose service role to the client) ---
# SUPABASE_URL=            # same project as VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY=
# MONTAGE_WORKER_SECRET=   # long random string; Edge Function uses the same value to call the worker
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# MONTAGE_MAX_USERS=25     # cap premium users processed per invocation
# PORT=8787                # optional; HTTP port for npm run montage-worker

# Supabase Edge Function `montage-cron` secrets (Dashboard → Functions → Secrets):
# CRON_SECRET=             # Bearer token for invoking the Edge Function (pg_cron / manual)
# VERCEL_MONTAGE_WORKER_URL=https://YOUR-WORKER.example.com   # full URL of montage worker (POST root)
# MONTAGE_WORKER_SECRET=   # must match worker MONTAGE_WORKER_SECRET

# --- Premium subscription / Stripe (Edge Functions `create-checkout-session` + `stripe-webhook`) ---
# Set via:  supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# STRIPE_SECRET_KEY=        # Stripe secret key (sk_test_... in dev, sk_live_... in prod)
# STRIPE_PRICE_ID=          # Price id of the premium subscription (price_...)
# STRIPE_WEBHOOK_SECRET=    # Signing secret from the Stripe dashboard → Webhooks
# SITE_URL=https://5pmsomewhere.app   # Used for Checkout success/cancel redirects
